Algoritmo "Operacoes.2"
Var
    N,Dobro,Triplo,Metade:Real
Inicio
    escreva("Me indique um número real: ")
    leia (N)

  Dobro <- N*2
  Triplo <- N*3
  Metade <- N/2

    escreval("O dobro de ",N," é: ", Dobro)
    escreval("O triplo de ",N," é:", Triplo)
    escrveal("E a metade de ",N," é: ", Metade)
Fimalgoritmo
