Algoritmo "MostrarDados"
Var
    N:caractere
    I:inteiro
    A:real
Inicio
    escreva("Qual é o seu nome?")
    leia(N)
    escreva("Qual a sua idade", N,"?")
    leia(I)
    escreva("E qual é a sua altura ",N,"?")
    leia(A)

    escreval("Nome: ",N)
    escreval("Idade: ",I)
    escreval("Altura: ",A)
FimAlgoritmo
