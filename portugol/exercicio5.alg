Algoritmo "CalculodeMedia"

Var
    N1,N2,N3:real
    Media:real

Inicio
    escreva("Informe a primeira nota: ")
    leia(N1)
    escreva("Agora, me informe a segunda nota: ")
    leia(N2)
    escreva("e por último, me informe a terceira nota")
    leia(N3)

    Media<-(N1+N2+N3)/3

    escreva("A sua média das notas ",N1", ",N2," e ",N3," é: ", Media")
Fimalgoritmo
