Algoritmo "AntecessoreSucessor"

Var
  N,Antecessor,Sucessor:Inteiro
Inicio
    escreva("Insira um número e te direi seu sucessor e antecessor.")
    leia(N)
  Antecessor <-N-1
  Sucessor<-N+1
    escreval("O antecessor de ",N," é: ", Antecessor)
    escreval("E o sucessor de ",N," é: ", Sucessor)
Fimalgoritmo
