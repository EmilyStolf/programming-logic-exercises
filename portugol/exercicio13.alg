Algoritmo "Trapezios"
Var
  Basemenor,BASEMAIOR,Ar,A:real 
Inicio
  escreva("Medida da base menor: ")
  leia(Basemenor)
  escreva("Medida da base maior: ")
  leia(BASEMAIOR)
  escreva("Medida da altura: ")
  leia(A)

  Ar<-((BASEMAIOR+Basemenor)*A)/2)

  escreva("A area do Trapézio é: ",Ar)
FimAlgoritmo
